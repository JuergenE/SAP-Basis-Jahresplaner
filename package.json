{
    "name": "sap-basis-planner",
    "version": "0.2.1",
    "description": "SAP Basis Jahresplaner mit SQLite-Backend und Multi-User-Support",
    "main": "server.js",
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "start": "node server.js",
        "dev": "node --watch server.js",
        "build:css": "npx @tailwindcss/cli -i ./input.css -o ./styles.css --minify",
        "dev:css": "npx @tailwindcss/cli -i ./input.css -o ./styles.css --watch",
        "build:js": "babel app.jsx --out-file app.js --presets @babel/preset-react",
        "dev:js": "babel app.jsx --out-file app.js --presets @babel/preset-react --watch",
        "test:api": "NODE_ENV=test DB_PATH=:memory: jest --config jest.config.js --json --outputFile=jest-results.json",
        "test:e2e": "npx playwright test",
        "test": "npm run test:api && npm run test:e2e"
    },
    "keywords": [
        "sap",
        "planner",
        "sqlite"
    ],
    "author": "Optima Solutions GmbH",
    "license": "UNLICENSED",
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "better-sqlite3": "^12.6.2",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "express": "^5.2.1",
        "express-rate-limit": "^8.2.1",
        "helmet": "^8.1.0",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@babel/cli": "^7.28.6",
        "@babel/preset-env": "^7.29.2",
        "@babel/preset-react": "^7.28.5",
        "@jest/globals": "^30.3.0",
        "@playwright/test": "^1.58.2",
        "@tailwindcss/cli": "^4.2.1",
        "dotenv": "^17.3.1",
        "jest": "^30.3.0",
        "supertest": "^7.2.2",
        "tailwindcss": "^4.2.1"
    }
}
